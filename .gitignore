# ignore image files
*.sif

# ignore object and shared object files
*.so
*.o

# ignore operating system files and temp files
.DS_Store
~*
*.swp

# Compiler-generated files
a.out
*.exe
*.mod
*.smod
*.sub
*.a
*.so
*.o
*.dylib
*.dll

# Ford-generated documentation folder
doc/html

# Python bytecode caches
__pycache__/

# Regenerable PDF grid caches (keyed to the .so hash; rebuild on demand)
*.npz

# fpm install output
bin/
