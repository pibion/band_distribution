# Ubuntu 26.04 LTS ships gfortran 15.2 as the default gfortran package,
# which supports the do concurrent locality specifiers (including the
# Fortran 2023 reduce clause) this project requires.
FROM ubuntu:26.04

ENV DEBIAN_FRONTEND=noninteractive

# python3-numpy/python3-scipy provide the packages needed by the python
# test scripts; python-is-python3 lets them be invoked as `python`
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    vim \
    gfortran \
    python3 \
    python-is-python3 \
    python3-numpy \
    python3-scipy \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set up working directory
WORKDIR /app

# Install fpm from source (bootstraps itself with gfortran)
# There is an fpm package on conda but building from source gives a
# newer version
RUN git clone https://github.com/fortran-lang/fpm \
    && cd fpm \
    && ./install.sh

ENV PATH="/root/.local/bin:${PATH}"

# Copy the fortran code over
# first we build the expected directory structure
# and then we copy files
RUN mkdir /app/src
RUN mkdir /app/test

COPY src /app/src/
COPY test /app/test
COPY fpm.toml /app/

# also copy over the python functions for testing
RUN mkdir /app/python
COPY python /app/python/

# Now compile the fortran code
RUN fpm test --compiler gfortran --profile release --flag "-march=native -fopenmp -ftree-parallelize-loops=4 -fcoarray=single -fPIC"
RUN fpm install --prefix=. --flag "-march=native -fopenmp -ftree-parallelize-loops=4 -fcoarray=single -fPIC"

# Needed to find the appropriate .so files from within python
ENV LD_LIBRARY_PATH=/app/lib
