FROM quay.io/jupyter/base-notebook

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
USER root

RUN apt-get update && apt-get install -y \
    git \
    gcc \
    vim \
    libtree \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Switch back to jovyan to avoid accidental container runs as root
USER $NB_UID

# instructions from
# https://jupyter-docker-stacks.readthedocs.io/en/latest/using/recipes.html#using-mamba-install-recommended-or-pip-install-in-a-child-docker-image
# ifx_linux-64 requires the Intel conda channel; fpm comes from conda-forge
RUN mamba install --yes \
    --channel https://software.repos.intel.com/python/conda \
    --channel conda-forge \
    ifx_linux-64 fpm && \
    mamba clean --all -f -y && \
    fix-permissions "${CONDA_DIR}" && \
    fix-permissions "/home/${NB_USER}"

# Install from the requirements.txt file
COPY --chown=${NB_UID}:${NB_GID} requirements.txt /tmp/
RUN mamba install --yes --file /tmp/requirements.txt && \
    mamba clean --all -f -y && \
    fix-permissions "${CONDA_DIR}" && \
    fix-permissions "/home/${NB_USER}"

WORKDIR /home/${NB_USER}

# Copy the fortran code over
RUN mkdir src test python
COPY --chown=${NB_UID}:${NB_GID} src/ src/
COPY --chown=${NB_UID}:${NB_GID} test/ test/
COPY --chown=${NB_UID}:${NB_GID} fpm.toml .
COPY --chown=${NB_UID}:${NB_GID} python/ python/

# Intel runtime libs (libimf.so etc.) live in the conda lib dir; needed at test-run time
ENV LD_LIBRARY_PATH=${CONDA_DIR}/lib:/home/jovyan/lib
# Preload Intel OpenMP runtime so __kmpc_* symbols resolve when ctypes loads libband_distribution.so
ENV LD_PRELOAD=${CONDA_DIR}/lib/libiomp5.so

# Now compile the fortran code
RUN fpm test --compiler ifx --flag "-fpp -O3 -qopenmp -DHAVE_MULTI_IMAGE_SUPPORT=0" --profile release \
    && fpm install --compiler ifx --flag "-fpp -O3 -qopenmp -DHAVE_MULTI_IMAGE_SUPPORT=0" --profile release --prefix .
