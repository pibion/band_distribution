FROM quay.io/jupyter/base-notebook

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
USER root

# fix-permissions at the end: under Rosetta emulation (Apple Silicon) the
# emulator writes $HOME/.cache/rosetta during this root-stage layer, and the
# image sets HOME=/home/jovyan globally, leaving .cache root-owned and
# breaking the later mamba install running as $NB_UID
RUN apt-get update && apt-get install -y \
    git \
    gcc \
    vim \
    libtree \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && fix-permissions "/home/${NB_USER}"

# Switch back to jovyan to avoid accidental container runs as root
USER $NB_UID

# Create the band conda environment from the same environment.yaml used by
# the other containers (ifx compiler, fpm, and all python packages), and
# register it as a notebook kernel so notebooks can select "Python (band)".
# Recipe: https://jupyter-docker-stacks.readthedocs.io/en/latest/using/recipes.html#add-a-custom-conda-environment-and-jupyter-kernel
COPY --chown=${NB_UID}:${NB_GID} environment.yaml /tmp/
RUN mamba env create -f /tmp/environment.yaml && \
    mamba run -n band python -m ipykernel install --user --name band --display-name "Python (band)" && \
    mamba clean --all -f -y && \
    fix-permissions "${CONDA_DIR}" && \
    fix-permissions "/home/${NB_USER}"

WORKDIR /home/${NB_USER}

# Copy the fortran code over
RUN mkdir src test python
COPY --chown=${NB_UID}:${NB_GID} src/ src/
COPY --chown=${NB_UID}:${NB_GID} test/ test/
COPY --chown=${NB_UID}:${NB_GID} fpm.toml .
COPY --chown=${NB_UID}:${NB_GID} python/ python/

# Intel runtime libs (libimf.so, libiomp5.so, ...) live in the band env's
# lib dir; needed when python ctypes loads libband_distribution.so
ENV LD_LIBRARY_PATH=${CONDA_DIR}/envs/band/lib:/home/jovyan/lib

# Link the Intel OpenMP runtime into everything fpm builds here; without
# -liomp5 the Python ctypes load fails on __kmpc_* symbols
ENV FPM_LDFLAGS="-liomp5"

# Now compile the fortran code with the band env's ifx and fpm
RUN mamba run -n band fpm test --compiler ifx --flag "-fpp -O3 -qopenmp -DHAVE_MULTI_IMAGE_SUPPORT=0" --profile release \
    && mamba run -n band fpm install --compiler ifx --flag "-fpp -O3 -qopenmp -DHAVE_MULTI_IMAGE_SUPPORT=0" --profile release --prefix .
